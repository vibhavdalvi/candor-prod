PORT=5000
# Database name used in MongoDB Atlas / Compass (collections: users, surveys, interviews).
# For Atlas SRV URIs without a path, this ensures data appears under this DB instead of "test".
MONGODB_DB=candor
MONGODB_URI=mongodb://localhost:27017/candor
# Any long random string you generate locally — used only to sign session JWTs (not from Google).
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
CLIENT_URL=http://localhost:3000

# Set to true in production when the API sits behind a reverse proxy (correct client IP for rate limiting).
# TRUST_PROXY=true

# Google Sign-In (OAuth Web client ID). Same value as REACT_APP_GOOGLE_CLIENT_ID in client/.env.
GOOGLE_CLIENT_ID=

# Email (optional - for sentinel alerts)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
EMAIL_FROM=alerts@candor.app
